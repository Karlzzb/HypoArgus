# HypoArgus 真实 LLM 配置（DashScope / 通义千问）
#
# 用法：把本文件复制为 .env（.env 已被 .gitignore 忽略，不会提交），
# 在下面填入你的 DashScope API key，然后直接跑：
#     python -m runtime.run_real input.txt -o final.md
#
# 获取 key：https://dashscope.console.aliyun.com  （阿里云 DashScope 控制台）
# 安全：key 只放 .env；切勿提交、切勿贴进聊天/日志/代码。

DASHSCOPE_API_KEY=

# 可选：覆盖默认模型（默认 qwen-max）。CLI 也可用 --model 覆盖。
# DASHSCOPE_MODEL=qwen-max

# --------------------------------------------------------------------------- #
# Langfuse 观测（可选；三变量任一缺失则不注入 callback，流水线行为不变）
#
# 配置齐全后 run_real 自动把 Langfuse LangChain handler 经 RunnableConfig.callbacks
# 注入整条 Agent 链路，全链 LLM 调用 / 图节点在 Langfuse 落 trace。
# 取值见 Langfuse 项目设置 → API 密钥；host 为自建 / Cloud 端点。
# 安全：密钥只放 .env；切勿提交、切勿贴进聊天/日志/代码。
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=http://localhost:13000
